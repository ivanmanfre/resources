0px);animation:fadeUp .6s .7s cubic-bezier(.16,1,.3,1) forwards}.cover .cover-details{opacity:0;transform:translateY(20px);animation:fadeUp .6s .9s cubic-bezier(.16,1,.3,1) forwards}@keyframes fadeUp{to{opacity:1;transform:translateY(0)}}.flow-step,.scope-item,.term-item,.roi-stat,.step-card,.case-study{transition:transform .3s cubic-bezier(.16,1,.3,1),border-color .3s,box-shadow .3s}.flow-step:hover,.scope-item:hover,.term-item:hover,.step-card:hover,.case-study:hover{transform:translateY(-4px);border-color:var(--green);box-shadow:0 8px 32px rgba(0,230,118,.08)}.roi-stat:hover{transform:translateY(-4px);border-color:var(--green);box-shadow:0 8px 32px rgba(0,230,118,.08)}.roi-stat:hover .roi-stat-value{text-shadow:0 0 24px rgba(0,230,118,.4)}.investment-box{transition:border-color .3s,box-shadow .3s}.investment-box:hover{box-shadow:0 0 48px rgba(0,230,118,.15)}.btn-primary{transition:transform .2s,box-shadow .2s}.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,230,118,.3)}.btn-secondary{transition:border-color .2s,color .2s}.btn-secondary:hover{border-color:var(--green);color:var(--green)}.timeline-table tr{transition:background .2s}.timeline-table tr:hover{background:rgba(0,230,118,.03)}.cover-nav{opacity:0;animation:fadeIn .8s .1s forwards}@keyframes fadeIn{to{opacity:1}}.payment-section{opacity:0;transform:scale(.96);transition:opacity .7s,transform .7s}.payment-section.visible{opacity:1;transform:scale(1)}</style>\n</head>\n<body>\n<div class=\"scroll-progress\"></div><div class=\"dot-bg\"></div>\n<div class=\"cover\"><div class=\"cover-nav\"><div class=\"logo\"><div class=\"logo-mark\">IM</div><span class=\"logo-text\">Iván Manfredi</span></div><span class=\"cover-meta\">PROPOSAL / March 8, 2026</span></div><div class=\"cover-tag\">AI &amp; Automation Architect</div><h1>Toast-Homebase Sales Data Automation</h1><p class=\"cover-sub\">A custom-built system to eliminate manual processes and replace operational drag with immutable infrastructure for .</p><div class=\"cover-details\"><div class=\"cover-detail\"><span class=\"cover-detail-label\">Prepared For</span><span class=\"cover-detail-value\">Chris</span></div><div class=\"cover-detail\"><span class=\"cover-detail-label\">Company</span><span class=\"cover-detail-value\"></span></div><div class=\"cover-detail\"><span class=\"cover-detail-label\">Delivery</span><span class=\"cover-detail-value\">1-2 weeks</span></div> <div class=\"cover-detail\"><span class=\"cover-detail-label\">Investment</span><span class=\"cover-detail-value\">$1500</span></div></div></div>\n<div class=\"section\"><span class=\"section-number\">01 / The Problem</span><h2>What's Costing You Time</h2><p> is currently losing productivity to manual processes that don't scale. Based on our discovery conversations:</p><div class=\"problem-card\"><p>Chris manually downloads daily sales data (date + net sales) from Toast POS and uploads CSV files into Homebase for each of his 4 restaurant locations. There is no integration between the two systems, requiring repetitive manual data transfer.</p></div><p>This is costing your team approximately <strong>3-5 hours per week</strong> in manual work, with additional risk from human error.</p></div>\n<div class=\"section\"><span class=\"section-number\">02 / The Solution</span><h2>What We're Building</h2><p>Automate the daily transfer of net sales data from Toast to Homebase across all 4 locations, eliminating manual CSV downloads and uploads so Homebase can generate labor cost reports automatically.</p><p>Using <strong>n8n</strong> as the automation backbone, integrated with Toast POS, Homebase, ADP / eliminating manual touchpoints while giving you full control.</p> <h3>System Flow</h3><div class=\"flow-grid\"><div class=\"flow-step\"><span class=\"flow-step-number\">Step 01</span><div class=\"flow-step-title\">Trigger</div><div class=\"flow-step-desc\">Daily scheduled trigger that runs automatically to pull the previous day's net sales data from Toast for each of the 4 restaurant locations</div></div> <div class=\"flow-step\"><span class=\"flow-step-number\">Step 02</span><div class=\"flow-step-title\">Process</div><div class=\"flow-step-desc\">n8n connects to the Toast API to retrieve daily net sales figures (date and total net sales) for each of the 4 locations, formats the data into the required two-column structure (date and net sales), and maps each location's data to the corresponding Homebase location</div></div> <div class=\"flow-step\"><span class=\"flow-step-number\">Step 03</span><div class=\"flow-step-title\">Output</div><div class=\"flow-step-desc\">Daily net sales data is automatically pushed into Homebase for all 4 locations, enabling Homebase to generate accurate labor-to-sales cost reports and other analytics</div></div> <div class=\"flow-step\"><span class=\"flow-step-number\">Step 04</span><div class=\"flow-step-title\">Notify</div><div class=\"flow-step-desc\">Stakeholders are notified via automated alerts upon successful daily sync completion or if any errors occur during the data transfer</div></div></div></div>\n<div class=\"section\"><span class=\"section-number\">03 / Scope of Work</span><h2>What's Included</h2><div class=\"scope-grid\"><div class=\"scope-item\"><div class=\"scope-check\">✓</div>Toast API integration &amp; data extraction</div><div class=\"scope-item\"><div class=\"scope-check\">✓</div>Homebase API integration &amp; data upload</div><div class=\"scope-item\"><div class=\"scope-check\">✓</div>Automated daily sync for all 4 locations</div><div class=\"scope-item\"><div class=\"scope-check\">✓</div>n8n workflow setup &amp; hosting configuration</div><div class=\"scope-item\"><div class=\"scope-check\">✓</div>Error handling &amp; failure notifications</div><div class=\"scope-item\"><div class=\"scope-check\">✓</div>Testing &amp; validation across all locations</div><div class=\"scope-item excluded\"><div class=\"scope-check\">×</div>Payroll automation (Homebase to ADP)</div><div class=\"scope-item excluded\"><div class=\"scope-check\">×</div>Employee communication/notification systems</div><div class=\"scope-item excluded\"><div class=\"scope-check\">×</div>Advanced reporting automations</div></div><h3>Not Included</h3><p>Payroll automation (Homebase to ADP), employee notification systems, advanced reporting, and any modifications to Toast or Homebase platform configurations.</p></div>\n<div class=\"section\"><span class=\"section-number\">04 / Timeline</span><h2>Delivery Schedule</h2><table class=\"timeline-table\"><thead><tr><th>Phase</th><th>Duration</th><th>Deliverable</th></tr></thead><tbody><tr><td class=\"phase-name\">Discovery &amp; API Verification</td><td class=\"phase-duration\">2-3 days</td><td class=\"phase-deliverable\">Confirmed API access for Toast and Homebase, documented data schema and authentication requirements</td></tr><tr><td class=\"phase-name\">Workflow Build &amp; Integration</td><td class=\"phase-duration\">3-4 days</td><td class=\"phase-deliverable\">n8n workflow connecting Toast to Homebase with daily automated data transfer for all 4 locations</td></tr><tr><td class=\"phase-name\">Testing &amp; Deployment</td><td class=\"phase-duration\">2-3 days</td><td class=\"phase-deliverable\">End-to-end testing across all locations, error handling implementation, and production deployment</td></tr></tbody></table><div class=\"timeline-total\">Total: 1-2 weeks</div></div>\n<div class=\"section\"><span class=\"section-number\">05 / Investment</span><h2>Pricing</h2><div class=\"investment-box\"><div class=\"investment-price\"><span class=\"investment-currency\">$</span> 1500</div><div class=\"investment-model\">Fixed project fee</div><div class=\"investment-terms\"><div class=\"investment-term\"><span class=\"investment-term-label\">Payment Terms</span><span class=\"investment-term-value\">50% upfront, 50% on delivery</span></div> <div class=\"investment-term\"><span class=\"investment-term-label\">Support Incl